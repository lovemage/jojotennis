# 複製成 .env.deploy 並填入（勿 commit .env.deploy）
# cp .env.deploy.example .env.deploy

# GitHub：https://github.com/settings/tokens → Generate new token (classic)
# 勾選：repo（完整倉庫權限）
GH_TOKEN=ghp_你的token

# 選填，預設 repo 名稱
GITHUB_REPO_NAME=TennisTW

# Netlify：https://app.netlify.com/user/applications → New access token
NETLIFY_AUTH_TOKEN=你的netlify_token
